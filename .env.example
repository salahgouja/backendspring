# ══════════════════════════════════════════════════════════
# Amen Bank — Core Banking API
# Environment Variables Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the .env file to version control!
# ══════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────
SERVER_PORT=8080

# ── PostgreSQL Database ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amenbank
DB_USERNAME=amenbank
DB_PASSWORD=your_secure_database_password

# ── Redis (Cache & Sessions) ──────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Authentication ────────────────────────────────
# Must be at least 256 bits (32+ characters) for HS256
JWT_SECRET=change-me-to-a-strong-random-secret-key-at-least-256-bits-long
# Access token expiration in ms (default: 24h = 86400000)
JWT_EXPIRATION=86400000
# Refresh token expiration in ms (default: 7d = 604800000)
JWT_REFRESH_EXPIRATION=604800000

# ── Email (SMTP — Gmail example) ─────────────────────
# Set EMAIL_ENABLED=true to activate email sending
EMAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
MAIL_PASSWORD=your_gmail_app_password

# ── Security ──────────────────────────────────────────
MIN_PASSWORD_LENGTH=8

# ── Transfer Limits (in TND) ─────────────────────────
MAX_TRANSFER_AMOUNT=100000.000
MAX_DAILY_TRANSFER=500000.000
MIN_TRANSFER_AMOUNT=0.001

# ── Fraud Detection Thresholds ───────────────────────
# Amount above which a transaction is flagged (TND)
FRAUD_AMOUNT_THRESHOLD=50000.000
# Time window in minutes for velocity check
FRAUD_VELOCITY_WINDOW=30
# Max transactions in velocity window before alert
FRAUD_VELOCITY_MAX=5

# ── File Uploads ─────────────────────────────────────
CREDIT_DOCS_DIR=./uploads/credit-documents

# ── CORS (comma-separated frontend URLs) ─────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

